{
	"$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
	"productName": "nipovpn-gui",
	"version": "0.2.0",
	"identifier": "com.aramus.nipovpngui",
	"build": {
		"devUrl": "http://localhost:5173",
		"beforeBuildCommand": "npm run build",
		"beforeDevCommand": "npm run dev",
		"frontendDist": "../build"
	},
	"app": {
		"windows": [
			{
				"title": "NipoVPN",
				"width": 1100,
				"height": 720,
				"minWidth": 950,
				"minHeight": 700,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"resources": ["bin/nipovpn/*"],
		"icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico"],
		"android": {
			"debugApplicationIdSuffix": ".debug"
		}
	}
}
